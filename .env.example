# ============================================================
#  Suite-OS Storage Gateway — Variables de entorno PRODUCCIÓN
#  Copiar a .env y completar con valores reales.
#  NUNCA subir .env al repo.
# ============================================================

NODE_ENV=production
LOG_LEVEL=info

# ── Postgres (interno al stack del storage) ─────────────────
POSTGRES_DB=suite_storage
POSTGRES_USER=storage_user
# Generar con: openssl rand -hex 16
POSTGRES_PASSWORD=COMPLETAR_PASSWORD_FUERTE_AQUI

# ── Redis (interno al stack del storage) ────────────────────
# Generar con: openssl rand -hex 16
REDIS_PASSWORD=COMPLETAR_PASSWORD_REDIS_AQUI

# ── Cifrado AES-256 de credentials guardados en DB ──────────
# Generar con: openssl rand -hex 32
ENCRYPTION_KEY=COMPLETAR_32_BYTES_HEX_AQUI

# ── API Key para autenticación entre backends ───────────────
# DepartmentOS y otros clientes la usan en header x-api-key
# Generar con: openssl rand -hex 24
INTERNAL_API_KEY=COMPLETAR_API_KEY_AQUI

# ── OAuth Google Drive (producción) ─────────────────────────
# Estas credenciales DEBEN ser de un Client OAuth diferente al de dev,
# con redirect_uri apuntando a storage.suite-os.app
GOOGLE_CLIENT_ID=tu_client_id_de_produccion.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu_client_secret_de_produccion
GOOGLE_CALLBACK_URL=https://storage.suite-os.app/api/v1/auth/google/callback

# ── Storage temporal (políticas de housekeeping) ────────────
DEFAULT_RETENTION_DAYS=90
ERROR_RETENTION_DAYS=30
MAX_UPLOAD_RETRIES=3

# ── URLs de redirección post-OAuth ──────────────────────────
DEPARMENTOS_URL=https://deparmentos.suite-os.app
INVENTORYOS_URL=https://inventoryos.suite-os.app

# ── CORS ────────────────────────────────────────────────────
# Frontends que pueden hacer requests al gateway
CORS_ORIGINS=https://deparmentos.suite-os.app,https://inventoryos.suite-os.app
