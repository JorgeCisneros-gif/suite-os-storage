# ─────────────────────────────────────────────────────
# suite-os-storage — variables de entorno
# Copia este archivo como .env y completa los valores
# NUNCA subas .env a git
# ─────────────────────────────────────────────────────

# PostgreSQL
POSTGRES_USER=storage_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=suite_storage

# Redis
REDIS_PASSWORD=CHANGE_ME_redis_password_here

# Cifrado AES-256 para credenciales OAuth
# Genera con: openssl rand -hex 32
ENCRYPTION_KEY=CHANGE_ME_32_char_hex_key_here_xx

# Google OAuth2
# Obtén en: console.cloud.google.com → Credenciales → OAuth 2.0
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_secret_here
GOOGLE_CALLBACK_URL=https://storage.suite-os.app/auth/google/callback

# JWT para tokens internos del gateway
JWT_SECRET=CHANGE_ME_jwt_secret_very_long_string

# Clave que tus otras apps (DepartmentOS, InventoryOS) usan para llamar al gateway
# Genera con: openssl rand -hex 24
INTERNAL_API_KEY=CHANGE_ME_internal_api_key_here

# Retención de archivos temporales (días)
DEFAULT_RETENTION_DAYS=90    # cuando el usuario no tiene Drive configurado
ERROR_RETENTION_DAYS=30      # cuando falla la subida al Drive del usuario

# Webhooks de las apps cliente (para notificaciones de eventos)
# El gateway hará POST a estas URLs cuando ocurra un evento de storage
DEPARMENTOS_WEBHOOK_URL=https://api.deparmentos.suite-os.app/webhooks/storage
INVENTORYOS_WEBHOOK_URL=https://api.inventoryos.suite-os.app/webhooks/storage

# URLs de redirección post-OAuth (frontends)
DEPARMENTOS_URL=https://deparmentos.suite-os.app
INVENTORYOS_URL=https://inventoryos.suite-os.app

# Solo dev
PGADMIN_PASSWORD=admin123
